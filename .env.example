# PHP Employee Performance Evaluation System - Environment Configuration

# Application Settings
APP_NAME="Employee Performance Evaluation System"
APP_VERSION="1.0.0"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
SECRET_KEY=change-me-in-production

# Database Configuration
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=performance_db
DB_USER=root
DB_PASS=

# Google Sheets API Configuration
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_CREDENTIALS_FILE=./config/credentials.json
GOOGLE_SHEETS_ID_SUPERVISOR=your-supervisor-sheet-id
GOOGLE_SHEETS_ID_PEER=your-peer-sheet-id
GOOGLE_SHEETS_ID_SUMMARY=your-summary-sheet-id

# Email Configuration
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your-mailtrap-username
MAIL_PASSWORD=your-mailtrap-password
MAIL_ENCRYPTION=tls
MAIL_FROM=noreply@yourcompany.com
MAIL_FROM_NAME=Performance Evaluation System

# Session Configuration
SESSION_TIMEOUT=3600
REMEMBER_ME_DURATION=604800

# Logging Configuration
LOG_LEVEL=info
LOG_PATH=./storage/logs
LOG_FILE=application.log

# Evaluation Settings
MIN_PEER_REVIEWS=4
MAX_PEER_REVIEWS=6
SUPERVISOR_WEIGHT=0.4
PEER_WEIGHT=0.6
OUTSTANDING_THRESHOLD=90
VERY_GOOD_THRESHOLD=80
GOOD_THRESHOLD=70
FAIR_THRESHOLD=60

# Performance Scoring
PERFORMANCE_MAX=30
PATIENT_CARE_MAX=20
TEAMWORK_MAX=20
RELIABILITY_MAX=15
INITIATIVE_MAX=15
TOTAL_MAX=100
